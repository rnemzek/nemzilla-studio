# environment variables

# Port the Hono/Vite dev & production server listens on.
PORT=3000

# development | production — controls whether server.ts mounts the Vite
# dev middleware or serves the static production build.
NODE_ENV=development

# Optional: LAN IP for testing the dev server from other devices on your network.
LOCALHOST_IP=

# UOW-13: required for the real LLM-backed AI PO discovery interview
# (src/server/services/poInterviewLLM.ts) and domain-agent semantic
# classification (src/server/services/domainAgents.ts). Both call Claude
# Haiku 4.5 and are real, billed API calls — every other part of this app
# stays fully simulated/free. Get a key at https://console.anthropic.com/ —
# never commit the real value.
ANTHROPIC_API_KEY=

# Pass C: optional. A Discord or Slack incoming-webhook URL — when set, fires
# a lightweight notification on high-intent visitor events (a Swarm Build
# launch, a "Would you hire/partner with me?" feedback submission). Unset by
# default; the app works identically without it (src/server/services/webhookNotifier.ts).
WEBHOOK_URL=

# Pass C: optional, both required together. When set, a visitor's Feedback &
# Review submission also opens a real GitHub Issue in this repo
# (owner/repo format) via a token with `repo`/`public_repo` issue-write scope.
# Unset by default — feedback is always persisted locally regardless
# (src/server/services/feedbackStore.ts); this just additionally files it as
# an issue (src/server/services/githubIssueClient.ts). Never commit the real token.
GITHUB_ISSUES_REPO=
GITHUB_TOKEN=
